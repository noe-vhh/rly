[
    {
        "id": "k8s-restart-pods",
        "name": "K8s: Restart Pods",
        "description": "Restart the CI deployment and wait for rollout",
        "type": "command",
        "shell": "wsl",
        "category": "kubernetes",
        "tags": ["k8s", "ci", "quick"],
        "command": "kubectl rollout restart deployment/my-app -n production && kubectl rollout status deployment/my-app -n production",
        "workingDirectory": "~",
        "parameters": [],
        "dangerLevel": "normal"
    },
    {
        "id": "k8s-delete-namespace",
        "name": "K8s: Delete Namespace",
        "description": "Permanently delete a kubernetes namespace and all its resources",
        "type": "command",
        "shell": "wsl",
        "category": "kubernetes",
        "tags": ["k8s", "destructive"],
        "command": "kubectl delete namespace production",
        "workingDirectory": "~",
        "parameters": [],
        "dangerLevel": "destructive"
    },
    {
        "id": "k8s-scale-down",
        "name": "K8s: Scale Down Deployment",
        "description": "Scale a deployment to zero replicas",
        "type": "command",
        "shell": "wsl",
        "category": "kubernetes",
        "tags": ["k8s", "warning"],
        "command": "kubectl scale deployment/my-app --replicas=0 -n production",
        "workingDirectory": "~",
        "parameters": [],
        "dangerLevel": "warning"
    },
    {
        "id": "docker-prune",
        "name": "Docker: System Prune",
        "description": "Remove all unused containers, networks, images and volumes",
        "type": "command",
        "shell": "bash",
        "category": "docker",
        "tags": ["docker", "cleanup"],
        "command": "docker system prune -a --volumes -f",
        "workingDirectory": "~",
        "parameters": [],
        "dangerLevel": "warning"
    },
    {
        "id": "docker-stop-all",
        "name": "Docker: Stop All Containers",
        "description": "Stop every running container on the host",
        "type": "command",
        "shell": "bash",
        "category": "docker",
        "tags": ["docker", "quick"],
        "command": "docker stop $(docker ps -aq)",
        "workingDirectory": "~",
        "parameters": [],
        "dangerLevel": "normal"
    },
    {
        "id": "db-drop-database",
        "name": "DB: Drop Production Database",
        "description": "Drops the production database — no recovery without a backup",
        "type": "command",
        "shell": "bash",
        "category": "database",
        "tags": ["db", "postgres"],
        "command": "psql -U admin -h localhost -c 'DROP DATABASE production;'",
        "workingDirectory": "~",
        "parameters": [],
        "dangerLevel": "destructive"
    },
    {
        "id": "wsl-update",
        "name": "WSL: Update & Upgrade Ubuntu",
        "description": "Full apt update, upgrade and autoremove",
        "type": "command",
        "shell": "wsl",
        "category": "system",
        "tags": ["wsl", "ubuntu", "maintenance"],
        "command": "echo 'Updating Ubuntu...' && sudo apt-get update && sudo apt-get -y upgrade && sudo apt-get autoremove && echo 'Done.'",
        "workingDirectory": "~",
        "parameters": [],
        "dangerLevel": "normal"
    },
    {
        "id": "relay-dev-start",
        "name": "Relay: Start Dev Server",
        "description": "Start relay in dev mode from WSL",
        "type": "command",
        "shell": "wsl",
        "category": "dev",
        "tags": ["relay", "dev"],
        "command": "cd ~/dev/relay && source .venv/bin/activate && python -m src.relay.main --dev",
        "workingDirectory": "~",
        "parameters": [],
        "dangerLevel": "normal"
    }
]